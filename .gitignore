# ==========================================
# Oficiální Terraform / OpenTofu ignorované soubory
# ==========================================

# Ignorovat lokální pracovní adresář Terraformu (.terraform/ obsahuje stažené providery a moduly)
.terraform/

# Ignorovat lokální lock soubor pro providery (volitelné, ale pro CI/CD se obvykle doporučuje .terraform.lock.hcl commitovat. 
# Pokud se ale střídá architektura nebo verze, někdy se ignoruje. Pro školní úkol klidně nechte commitovaný, nebo ho zakomentujte.)
# .terraform.lock.hcl

# Ignorovat soubory se stavy (State), pokud bys omylem spustil terraform apply lokálně.
# Tvůj stav bude bezpečně v S3 bucketu, ale lokální kopie nebo zálohy v repozitáři nechceš.
*.tfstate
*.tfstate.*

# Ignorovat crash logy
crash.log
crash.*.log

# Ignorovat soubory s citlivými proměnnými (ZDE POZOR!)
# Tvůj soubor `terraform.tfvars` ze zadání neobsahuje hesla, ale obecně se doporučuje ho necommitovat, 
# pokud obsahuje tajná data. V našem případě ho commitovat MŮŽEŠ, pokud chceš předat defaultní hodnoty.
# Pokud bys ale vytvořil soubor s tajnými údaji, ignoruj ho:
# *.tfvars
# *.tfvars.json

# Ignorovat lokální override soubory
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignorovat tajné klíče a CLI konfigurace
.terraformrc
terraform.rc

# ==========================================
# Vývojové nástroje a OS (VS Code, MobaXterm, RHEL)
# ==========================================

# VS Code konfigurace specifická pro tvůj počítač/virtuálku
.vscode/
!.vscode/extensions.json

# MobaXterm nebo jiné lokální logy z SSH relací
*.log

# Systémové soubory
.DS_Store
Thumbs.db